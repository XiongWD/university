# ============================================================
# 河南志愿推 — 环境变量配置模板
# 复制此文件为 .env 并填入你的 API Key
# ============================================================

# --- LLM / AI 配置（必填，否则 AI 功能不可用）---
# API 地址（兼容 OpenAI Chat Completions API 的服务商均可）
OPENAI_BASE_URL=https://api.deepseek.com
# API Key（必填）
OPENAI_API_KEY=sk-your-api-key-here
# 模型名称
OPENAI_MODEL=deepseek-chat

# --- AI 参数（可选，使用默认值即可）---
# 最大输出 token 数
# AI_MAX_TOKENS=4096
# 温度参数（0-2，越低越确定性）
# AI_TEMPERATURE=0.7
